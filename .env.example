# TikTok Developer Portal > Manage apps içinden al
TIKTOK_CLIENT_KEY=buraya_client_key
TIKTOK_CLIENT_SECRET=buraya_client_secret

# Desktop redirect URI olarak TikTok Developer Portal'a aynen ekle:
# http://localhost:3455/callback/
TIKTOK_REDIRECT_URI=http://localhost:3455/callback/

# Direct Post için en az video.publish gerekir.
TIKTOK_SCOPES=user.info.basic,video.publish

# Zamanlama saat dilimi
APP_TIMEZONE=Europe/Istanbul

# Test için true yaparsan API'ye video göndermez, sadece log basar.
TIKTOK_DRY_RUN=false
